{
  "name": "{slug}",
  "path": "/order-flow/{slug}",
  "depth_level": 2,
  "breadcrumb": ["Home", "Order Flow", "{display_name}"],
  "parent": "/order-flow",
  "category": "orderFlow",

  "meta": {
    "title": {
      "type": "string",
      "required": true,
      "minLength": 35,
      "maxLength": 55
    },
    "description": {
      "type": "string",
      "required": true,
      "minLength": 120,
      "maxLength": 155
    },
    "canonical": { "type": "string", "required": true, "format": "uri" }
  },

  "seo_schema": {
    "@context": {
      "type": "string",
      "required": true,
      "const": "https://schema.org"
    },
    "@type": { "type": "string", "required": true, "const": "TechArticle" },
    "headline": {
      "type": "string",
      "required": true,
      "minLength": 35,
      "maxLength": 100
    },
    "datePublished": { "type": "string", "required": true, "format": "date" },
    "dateModified": { "type": "string", "required": true, "format": "date" }
  },

  "aeo": {
    "direct_answer": {
      "type": "string",
      "required": true,
      "minLength": 100,
      "maxLength": 200
    },
    "key_takeaways": {
      "type": "array",
      "required": true,
      "minItems": 3,
      "maxItems": 4,
      "items": { "type": "string", "minLength": 40, "maxLength": 100 }
    },
    "people_also_ask": {
      "type": "array",
      "required": true,
      "minItems": 2,
      "maxItems": 3,
      "items": {
        "type": "object",
        "properties": {
          "question": { "type": "string", "minLength": 30, "maxLength": 90 },
          "answer": { "type": "string", "minLength": 60, "maxLength": 200 }
        }
      }
    }
  },

  "order_flow_specific": {
    "type": {
      "type": "string",
      "required": true,
      "enum": [
        "delta",
        "cumulative_delta",
        "divergence",
        "absorption",
        "exhaustion",
        "imbalance",
        "aggressor",
        "passive",
        "liquidity",
        "microstructure",
        "order_book",
        "tape_reading",
        "iceberg",
        "spoofing",
        "quote_stuffing",
        "latency_arbitrage"
      ]
    },
    "calculation_method": {
      "type": "string",
      "required": false,
      "enum": [
        "tick_delta",
        "volume_delta",
        "bid_ask_imbalance",
        "order_flow_imbalance",
        "cumulative_sum"
      ]
    },
    "data_source": {
      "type": "string",
      "required": false,
      "enum": ["tape", "order_book", "time_sales", "market_depth", "tick_data"]
    },
    "default_period": {
      "type": "number",
      "required": true,
      "minimum": 1,
      "maximum": 200
    },
    "lagging": { "type": "boolean", "required": true },
    "supports_divergence": { "type": "boolean", "required": true },
    "real_time": { "type": "boolean", "required": true },

    "interactive_config": {
      "type": "object",
      "required": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "simulator_type": {
          "type": "string",
          "enum": [
            "order_flow_simulator",
            "delta_analyzer",
            "imbalance_detector",
            "tape_simulator"
          ]
        },
        "real_time": { "type": "boolean", "default": false },
        "parameters": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "label": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["range", "select", "boolean", "number", "period"]
              },
              "default": { "type": "number" },
              "min": { "type": "number" },
              "max": { "type": "number" },
              "step": { "type": "number" },
              "unit": { "type": "string" },
              "description": { "type": "string" },
              "options": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "value": { "type": "string" },
                    "label": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "presets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "params": { "type": "object" },
              "description": { "type": "string" }
            }
          }
        },
        "default_threshold": { "type": "number", "default": 0.7 },
        "show_divergence": { "type": "boolean", "default": true },
        "show_absorption": { "type": "boolean", "default": true }
      }
    },

    "signal_metrics": {
      "type": "object",
      "required": false,
      "properties": {
        "bullish_threshold": { "type": "number" },
        "bearish_threshold": { "type": "number" },
        "divergence_strength": { "type": "string" },
        "absorption_level": { "type": "string" }
      }
    },

    "comparison_indicators": {
      "type": "array",
      "required": false,
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "signal_quality": { "type": "string" },
          "lag_amount": { "type": "string" },
          "best_timeframe": { "type": "string" }
        }
      }
    }
  },

  "authority_assets": {
    "calculator": { "type": "string", "required": true, "format": "uri" },
    "code_hub": { "type": "string", "required": true, "format": "uri" },
    "interactive_simulator": {
      "type": "string",
      "required": false,
      "format": "uri"
    },
    "comparisons": {
      "type": "array",
      "required": false,
      "maxItems": 4,
      "items": { "type": "string", "format": "uri" }
    },
    "examples": {
      "type": "array",
      "required": false,
      "maxItems": 3,
      "items": { "type": "string", "format": "uri" }
    },
    "benchmarks": {
      "type": "array",
      "required": false,
      "maxItems": 3,
      "items": { "type": "string", "format": "uri" }
    },
    "related_order_flow": {
      "type": "array",
      "required": false,
      "maxItems": 5,
      "items": { "type": "string", "format": "uri" }
    },
    "related_microstructure": {
      "type": "array",
      "required": false,
      "maxItems": 3,
      "items": { "type": "string", "format": "uri" }
    }
  },

  "content_sections": {
    "required": {
      "minItems": 5,
      "maxItems": 5,
      "items": [
        {
          "id": { "type": "string", "const": "quick_answer" },
          "type": { "type": "string", "const": "highlight_box" },
          "title": {
            "type": "string",
            "required": true,
            "minLength": 10,
            "maxLength": 30
          },
          "content": {
            "type": "string",
            "required": true,
            "minLength": 80,
            "maxLength": 150
          }
        },
        {
          "id": { "type": "string", "const": "interactive_simulator" },
          "type": { "type": "string", "const": "interactive_widget" },
          "title": {
            "type": "string",
            "required": true,
            "minLength": 15,
            "maxLength": 35
          },
          "widget_type": { "type": "string", "const": "order_flow_simulator" }
        },
        {
          "id": { "type": "string", "const": "formula" },
          "type": { "type": "string", "const": "code_block" },
          "title": {
            "type": "string",
            "required": true,
            "minLength": 5,
            "maxLength": 20
          },
          "content": {
            "type": "string",
            "required": true,
            "minLength": 50,
            "maxLength": 300
          }
        },
        {
          "id": { "type": "string", "const": "signals" },
          "type": { "type": "string", "const": "signal_table" },
          "title": {
            "type": "string",
            "required": true,
            "minLength": 15,
            "maxLength": 35
          },
          "rows": {
            "type": "array",
            "required": true,
            "minItems": 3,
            "maxItems": 5,
            "items": {
              "type": "object",
              "properties": {
                "signal": {
                  "type": "string",
                  "minLength": 20,
                  "maxLength": 40
                },
                "meaning": {
                  "type": "string",
                  "minLength": 30,
                  "maxLength": 80
                }
              }
            }
          }
        },
        {
          "id": { "type": "string", "const": "code_implementations" },
          "type": { "type": "string", "const": "language_grid" },
          "title": {
            "type": "string",
            "required": true,
            "minLength": 15,
            "maxLength": 30
          },
          "languages": {
            "type": "array",
            "required": true,
            "minItems": 6,
            "maxItems": 22,
            "items": {
              "type": "string",
              "enum": [
                "python",
                "rust",
                "go",
                "cpp",
                "java",
                "javascript",
                "typescript",
                "csharp",
                "ruby",
                "swift",
                "kotlin",
                "php",
                "r",
                "julia",
                "scala",
                "haskell",
                "ocaml",
                "fsharp",
                "matlab",
                "zig",
                "dotnet",
                "sql"
              ]
            }
          }
        }
      ]
    },
    "recommended": {
      "minItems": 0,
      "maxItems": 5,
      "items": [
        {
          "id": {
            "type": "string",
            "enum": [
              "how_it_works",
              "calculation_example",
              "trading_strategies",
              "pros_cons",
              "divergence_detection",
              "absorption_analysis",
              "real_time_application"
            ]
          },
          "type": {
            "type": "string",
            "enum": ["text", "step_by_step", "cards", "two_columns", "chart"]
          },
          "title": {
            "type": "string",
            "required": true,
            "minLength": 10,
            "maxLength": 35
          },
          "content": {
            "type": "string",
            "required": false,
            "minLength": 150,
            "maxLength": 400
          },
          "items": {
            "type": "array",
            "required": false,
            "minItems": 2,
            "maxItems": 5
          },
          "chart_config": {
            "type": "object",
            "required": false,
            "properties": {
              "type": {
                "type": "string",
                "enum": ["delta", "cumulative", "profile"]
              },
              "x_axis": { "type": "string" },
              "y_axis": { "type": "string" }
            }
          }
        }
      ]
    },
    "optional": {
      "minItems": 0,
      "maxItems": 4,
      "items": [
        {
          "id": {
            "type": "string",
            "enum": [
              "history",
              "market_conditions",
              "common_mistakes",
              "tick_analysis",
              "footprint_charts"
            ]
          },
          "type": {
            "type": "string",
            "enum": ["text", "code_block", "warning_box"]
          },
          "title": {
            "type": "string",
            "required": true,
            "minLength": 5,
            "maxLength": 25
          },
          "content": {
            "type": "string",
            "required": true,
            "minLength": 100,
            "maxLength": 300
          },
          "code": { "type": "string", "required": false },
          "language": { "type": "string", "required": false }
        }
      ]
    }
  },

  "engagement_widgets": {
    "interactive_simulator": { "type": "boolean", "required": true },
    "calculator_preview": { "type": "boolean", "required": true },
    "code_language_selector": { "type": "boolean", "required": true },
    "comparison_links": { "type": "boolean", "required": true },
    "related_order_flow": { "type": "boolean", "required": true },
    "faq_accordion": { "type": "boolean", "required": true },
    "delta_visualizer": { "type": "boolean", "required": false },
    "tape_simulator": { "type": "boolean", "required": false },
    "divergence_detector": { "type": "boolean", "required": false },
    "export_data": { "type": "boolean", "required": false }
  },

  "visualization_config": {
    "type": "object",
    "required": false,
    "properties": {
      "default_chart": {
        "type": "string",
        "enum": [
          "cumulative_delta",
          "delta_profile",
          "imbalance_heatmap",
          "tape_animation"
        ]
      },
      "color_scheme": {
        "type": "string",
        "enum": ["default", "bid_ask", "delta"]
      },
      "show_divergence": { "type": "boolean", "default": true },
      "animate_tape": { "type": "boolean", "default": true },
      "show_absorption": { "type": "boolean", "default": true }
    }
  },

  "faq": {
    "type": "array",
    "required": true,
    "minItems": 2,
    "maxItems": 4,
    "items": {
      "type": "object",
      "properties": {
        "q": { "type": "string", "minLength": 20, "maxLength": 90 },
        "a": { "type": "string", "minLength": 80, "maxLength": 250 }
      }
    }
  },

  "metadata": {
    "estimated_read_time": {
      "type": "string",
      "required": true,
      "pattern": "^\\d+ min read$"
    },
    "last_updated": { "type": "string", "required": true, "format": "date" },
    "difficulty": {
      "type": "string",
      "required": true,
      "enum": ["beginner", "intermediate", "advanced", "expert"]
    },
    "content_type": {
      "type": "string",
      "required": true,
      "const": "order_flow_guide"
    },
    "tags": {
      "type": "array",
      "required": true,
      "minItems": 2,
      "maxItems": 5,
      "items": { "type": "string", "minLength": 3, "maxLength": 15 }
    },
    "featured": { "type": "boolean", "required": false, "default": false },
    "popularity_score": {
      "type": "number",
      "required": false,
      "minimum": 0,
      "maximum": 100
    }
  }
}
