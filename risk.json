{
  "name": "{slug}",
  "path": "/risk/{slug}",
  "depth_level": 2,
  "breadcrumb": ["Home", "Risk Metrics", "{display_name}"],
  "parent": "/risk",
  "category": "risk",

  "meta": {
    "title": {
      "type": "string",
      "required": true,
      "minLength": 35,
      "maxLength": 55
    },
    "description": {
      "type": "string",
      "required": true,
      "minLength": 120,
      "maxLength": 155
    },
    "canonical": { "type": "string", "required": true, "format": "uri" }
  },

  "seo_schema": {
    "@context": {
      "type": "string",
      "required": true,
      "const": "https://schema.org"
    },
    "@type": { "type": "string", "required": true, "const": "TechArticle" },
    "headline": {
      "type": "string",
      "required": true,
      "minLength": 35,
      "maxLength": 100
    },
    "datePublished": { "type": "string", "required": true, "format": "date" },
    "dateModified": { "type": "string", "required": true, "format": "date" }
  },

  "aeo": {
    "direct_answer": {
      "type": "string",
      "required": true,
      "minLength": 100,
      "maxLength": 200
    },
    "key_takeaways": {
      "type": "array",
      "required": true,
      "minItems": 3,
      "maxItems": 4,
      "items": { "type": "string", "minLength": 40, "maxLength": 100 }
    },
    "people_also_ask": {
      "type": "array",
      "required": true,
      "minItems": 2,
      "maxItems": 3,
      "items": {
        "type": "object",
        "properties": {
          "question": { "type": "string", "minLength": 30, "maxLength": 90 },
          "answer": { "type": "string", "minLength": 60, "maxLength": 200 }
        }
      }
    }
  },

  "risk_specific": {
    "type": {
      "type": "string",
      "required": true,
      "enum": [
        "performance_ratio",
        "drawdown",
        "value_at_risk",
        "tail_risk",
        "sensitivity_measure",
        "concentration_measure",
        "systemic_risk",
        "stress_testing",
        "risk_framework",
        "attribution",
        "factor_risk",
        "counterparty_risk",
        "operational_risk"
      ]
    },
    "measurement_scale": {
      "type": "string",
      "required": false,
      "enum": ["ratio", "percentage", "absolute", "relative", "probability"]
    },
    "higher_is_better": {
      "type": "boolean",
      "required": true
    },
    "range_min": {
      "type": "number",
      "required": false
    },
    "range_max": {
      "type": "number",
      "required": false
    },
    "threshold_good": {
      "type": "number",
      "required": false
    },
    "threshold_bad": {
      "type": "number",
      "required": false
    },
    "time_horizon": {
      "type": "string",
      "required": false,
      "enum": ["daily", "monthly", "annual", "multi_year", "intraday"]
    },
    "confidence_level": {
      "type": "number",
      "required": false,
      "minimum": 0,
      "maximum": 100
    },
    "requires_distribution_assumption": { "type": "boolean", "required": true },
    "parametric": { "type": "boolean", "required": true },
    "non_parametric": { "type": "boolean", "required": true },

    "interactive_config": {
      "type": "object",
      "required": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "simulator_type": {
          "type": "string",
          "enum": [
            "risk_calculator",
            "var_simulator",
            "drawdown_analyzer",
            "stress_tester"
          ]
        },
        "real_time": { "type": "boolean", "default": false },
        "parameters": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "label": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["range", "select", "boolean", "number", "confidence"]
              },
              "default": { "type": "number" },
              "min": { "type": "number" },
              "max": { "type": "number" },
              "step": { "type": "number" },
              "unit": { "type": "string" },
              "description": { "type": "string" },
              "options": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "value": { "type": "string" },
                    "label": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "presets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "params": { "type": "object" },
              "description": { "type": "string" }
            }
          }
        },
        "default_confidence": { "type": "number", "default": 95 },
        "default_horizon_days": { "type": "number", "default": 1 },
        "show_distribution": { "type": "boolean", "default": true },
        "show_tail_analysis": { "type": "boolean", "default": true }
      }
    },

    "risk_metrics": {
      "type": "object",
      "required": false,
      "properties": {
        "typical_value": { "type": "string" },
        "target_value": { "type": "string" },
        "calculation_method": { "type": "string" }
      }
    },

    "comparison_metrics": {
      "type": "array",
      "required": false,
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "robustness": { "type": "string" },
          "complexity": { "type": "string" },
          "interpretability": { "type": "string" }
        }
      }
    }
  },

  "authority_assets": {
    "calculator": { "type": "string", "required": true, "format": "uri" },
    "code_hub": { "type": "string", "required": true, "format": "uri" },
    "interactive_simulator": {
      "type": "string",
      "required": false,
      "format": "uri"
    },
    "comparisons": {
      "type": "array",
      "required": false,
      "maxItems": 4,
      "items": { "type": "string", "format": "uri" }
    },
    "examples": {
      "type": "array",
      "required": false,
      "maxItems": 3,
      "items": { "type": "string", "format": "uri" }
    },
    "benchmarks": {
      "type": "array",
      "required": false,
      "maxItems": 3,
      "items": { "type": "string", "format": "uri" }
    },
    "related_risk_metrics": {
      "type": "array",
      "required": false,
      "maxItems": 5,
      "items": { "type": "string", "format": "uri" }
    },
    "alternative_metrics": {
      "type": "array",
      "required": false,
      "maxItems": 3,
      "items": { "type": "string", "format": "uri" }
    },
    "regulatory_references": {
      "type": "array",
      "required": false,
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string", "format": "uri" }
        }
      }
    }
  },

  "content_sections": {
    "required": {
      "minItems": 5,
      "maxItems": 5,
      "items": [
        {
          "id": { "type": "string", "const": "quick_answer" },
          "type": { "type": "string", "const": "highlight_box" },
          "title": {
            "type": "string",
            "required": true,
            "minLength": 10,
            "maxLength": 30
          },
          "content": {
            "type": "string",
            "required": true,
            "minLength": 80,
            "maxLength": 150
          }
        },
        {
          "id": { "type": "string", "const": "interactive_risk" },
          "type": { "type": "string", "const": "interactive_widget" },
          "title": {
            "type": "string",
            "required": true,
            "minLength": 15,
            "maxLength": 35
          },
          "widget_type": { "type": "string", "const": "risk_simulator" }
        },
        {
          "id": { "type": "string", "const": "formula" },
          "type": { "type": "string", "const": "code_block" },
          "title": {
            "type": "string",
            "required": true,
            "minLength": 5,
            "maxLength": 20
          },
          "content": {
            "type": "string",
            "required": true,
            "minLength": 50,
            "maxLength": 300
          }
        },
        {
          "id": { "type": "string", "const": "interpretation" },
          "type": { "type": "string", "const": "signal_table" },
          "title": {
            "type": "string",
            "required": true,
            "minLength": 15,
            "maxLength": 35
          },
          "rows": {
            "type": "array",
            "required": true,
            "minItems": 3,
            "maxItems": 5,
            "items": {
              "type": "object",
              "properties": {
                "value_range": {
                  "type": "string",
                  "minLength": 20,
                  "maxLength": 40
                },
                "interpretation": {
                  "type": "string",
                  "minLength": 30,
                  "maxLength": 80
                }
              }
            }
          }
        },
        {
          "id": { "type": "string", "const": "code_implementations" },
          "type": { "type": "string", "const": "language_grid" },
          "title": {
            "type": "string",
            "required": true,
            "minLength": 15,
            "maxLength": 30
          },
          "languages": {
            "type": "array",
            "required": true,
            "minItems": 6,
            "maxItems": 22,
            "items": {
              "type": "string",
              "enum": [
                "python",
                "rust",
                "go",
                "cpp",
                "java",
                "javascript",
                "typescript",
                "csharp",
                "ruby",
                "swift",
                "kotlin",
                "php",
                "r",
                "julia",
                "scala",
                "haskell",
                "ocaml",
                "fsharp",
                "matlab",
                "zig",
                "dotnet",
                "sql"
              ]
            }
          }
        }
      ]
    },
    "recommended": {
      "minItems": 0,
      "maxItems": 5,
      "items": [
        {
          "id": {
            "type": "string",
            "enum": [
              "how_it_works",
              "calculation_example",
              "practical_application",
              "pros_cons",
              "comparison_chart",
              "limitations",
              "regulatory_context"
            ]
          },
          "type": {
            "type": "string",
            "enum": ["text", "step_by_step", "cards", "two_columns", "chart"]
          },
          "title": {
            "type": "string",
            "required": true,
            "minLength": 10,
            "maxLength": 35
          },
          "content": {
            "type": "string",
            "required": false,
            "minLength": 150,
            "maxLength": 400
          },
          "items": {
            "type": "array",
            "required": false,
            "minItems": 2,
            "maxItems": 5
          },
          "chart_config": {
            "type": "object",
            "required": false,
            "properties": {
              "type": {
                "type": "string",
                "enum": ["distribution", "tail_plot", "backtest"]
              },
              "x_axis": { "type": "string" },
              "y_axis": { "type": "string" }
            }
          }
        }
      ]
    },
    "optional": {
      "minItems": 0,
      "maxItems": 4,
      "items": [
        {
          "id": {
            "type": "string",
            "enum": [
              "history",
              "regulatory_context",
              "common_misinterpretations",
              "advanced_topics",
              "implementation_notes"
            ]
          },
          "type": {
            "type": "string",
            "enum": ["text", "code_block", "warning_box"]
          },
          "title": {
            "type": "string",
            "required": true,
            "minLength": 5,
            "maxLength": 25
          },
          "content": {
            "type": "string",
            "required": true,
            "minLength": 100,
            "maxLength": 300
          },
          "code": { "type": "string", "required": false },
          "language": { "type": "string", "required": false }
        }
      ]
    }
  },

  "engagement_widgets": {
    "interactive_risk": { "type": "boolean", "required": true },
    "calculator_preview": { "type": "boolean", "required": true },
    "code_language_selector": { "type": "boolean", "required": true },
    "comparison_links": { "type": "boolean", "required": true },
    "related_risk_metrics": { "type": "boolean", "required": true },
    "faq_accordion": { "type": "boolean", "required": true },
    "risk_distribution": { "type": "boolean", "required": false },
    "backtest_visualization": { "type": "boolean", "required": false },
    "export_risk_report": { "type": "boolean", "required": false }
  },

  "visualization_config": {
    "type": "object",
    "required": false,
    "properties": {
      "default_chart": {
        "type": "string",
        "enum": ["distribution", "tail_plot", "backtest", "heatmap"]
      },
      "color_scheme": {
        "type": "string",
        "enum": ["default", "risk", "confidence"]
      },
      "show_confidence_bands": { "type": "boolean", "default": true },
      "animate_calculation": { "type": "boolean", "default": true },
      "show_tail_sensitivity": { "type": "boolean", "default": true }
    }
  },

  "faq": {
    "type": "array",
    "required": true,
    "minItems": 2,
    "maxItems": 4,
    "items": {
      "type": "object",
      "properties": {
        "q": { "type": "string", "minLength": 20, "maxLength": 90 },
        "a": { "type": "string", "minLength": 80, "maxLength": 250 }
      }
    }
  },

  "metadata": {
    "estimated_read_time": {
      "type": "string",
      "required": true,
      "pattern": "^\\d+ min read$"
    },
    "last_updated": { "type": "string", "required": true, "format": "date" },
    "difficulty": {
      "type": "string",
      "required": true,
      "enum": ["beginner", "intermediate", "advanced", "expert"]
    },
    "content_type": {
      "type": "string",
      "required": true,
      "const": "risk_guide"
    },
    "tags": {
      "type": "array",
      "required": true,
      "minItems": 2,
      "maxItems": 5,
      "items": { "type": "string", "minLength": 3, "maxLength": 15 }
    },
    "featured": { "type": "boolean", "required": false, "default": false },
    "popularity_score": {
      "type": "number",
      "required": false,
      "minimum": 0,
      "maximum": 100
    }
  }
}
