{
  "name": "{slug}",
  "path": "/execution/{slug}",
  "depth_level": 2,
  "breadcrumb": ["Home", "Execution Algorithms", "{display_name}"],
  "parent": "/execution",
  "category": "execution",

  "meta": {
    "title": {
      "type": "string",
      "required": true,
      "minLength": 35,
      "maxLength": 55
    },
    "description": {
      "type": "string",
      "required": true,
      "minLength": 120,
      "maxLength": 155
    },
    "canonical": { "type": "string", "required": true, "format": "uri" }
  },

  "seo_schema": {
    "@context": {
      "type": "string",
      "required": true,
      "const": "https://schema.org"
    },
    "@type": { "type": "string", "required": true, "const": "TechArticle" },
    "headline": {
      "type": "string",
      "required": true,
      "minLength": 35,
      "maxLength": 100
    },
    "datePublished": { "type": "string", "required": true, "format": "date" },
    "dateModified": { "type": "string", "required": true, "format": "date" }
  },

  "aeo": {
    "direct_answer": {
      "type": "string",
      "required": true,
      "minLength": 100,
      "maxLength": 200
    },
    "key_takeaways": {
      "type": "array",
      "required": true,
      "minItems": 3,
      "maxItems": 4,
      "items": { "type": "string", "minLength": 40, "maxLength": 100 }
    },
    "people_also_ask": {
      "type": "array",
      "required": true,
      "minItems": 2,
      "maxItems": 3,
      "items": {
        "type": "object",
        "properties": {
          "question": { "type": "string", "minLength": 30, "maxLength": 90 },
          "answer": { "type": "string", "minLength": 60, "maxLength": 200 }
        }
      }
    }
  },

  "execution_specific": {
    "type": {
      "type": "string",
      "required": true,
      "enum": [
        "order_type",
        "algorithm",
        "benchmark",
        "protocol",
        "infrastructure",
        "risk_control",
        "access_method",
        "performance"
      ]
    },
    "algorithm_category": {
      "type": "string",
      "required": false,
      "enum": [
        "scheduled",
        "volume_participation",
        "opportunistic",
        "intelligent",
        "adaptive",
        "ml_based"
      ]
    },
    "execution_style": {
      "type": "string",
      "required": true,
      "enum": ["passive", "aggressive", "midpoint", "adaptive", "dark", "lit"]
    },
    "urgency": {
      "type": "string",
      "required": true,
      "enum": ["low", "medium", "high", "immediate"]
    },
    "market_impact_control": {
      "type": "string",
      "required": true,
      "enum": ["low", "medium", "high", "very_high"]
    },
    "timing_risk": {
      "type": "string",
      "required": true,
      "enum": ["low", "medium", "high"]
    },
    "latency_sensitivity": {
      "type": "string",
      "required": true,
      "enum": ["low", "medium", "high", "ultra_low"]
    },
    "typical_participation_rate": {
      "type": "number",
      "required": false,
      "minimum": 0,
      "maximum": 50
    },
    "supports_iceberg": { "type": "boolean", "required": true },
    "supports_dark_pools": { "type": "boolean", "required": true },
    "supports_multi_leg": { "type": "boolean", "required": true },
    "implementation_shortfall_target": {
      "type": "number",
      "required": false,
      "minimum": 0,
      "maximum": 100
    },

    "interactive_config": {
      "type": "object",
      "required": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "simulator_type": {
          "type": "string",
          "enum": [
            "execution_simulator",
            "cost_analyzer",
            "slippage_calculator",
            "performance_visualizer"
          ]
        },
        "real_time": { "type": "boolean", "default": false },
        "parameters": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "label": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["range", "select", "boolean", "number"]
              },
              "default": { "type": "number" },
              "min": { "type": "number" },
              "max": { "type": "number" },
              "step": { "type": "number" },
              "unit": { "type": "string" },
              "options": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "value": { "type": "string" },
                    "label": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "presets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "params": { "type": "object" },
              "description": { "type": "string" }
            }
          }
        },
        "default_order_size": { "type": "number", "default": 10000 },
        "default_volume": { "type": "number", "default": 1000000 }
      }
    },

    "performance_metrics": {
      "type": "object",
      "required": false,
      "properties": {
        "expected_slippage_bps": { "type": "number" },
        "market_impact_bps": { "type": "number" },
        "implementation_shortfall_bps": { "type": "number" },
        "participation_rate_pct": { "type": "number" },
        "completion_time_ratio": { "type": "number" },
        "urgency_adjustment_factor": { "type": "number" }
      }
    },

    "cost_model": {
      "type": "object",
      "required": false,
      "properties": {
        "fixed_cost_bps": { "type": "number" },
        "variable_cost_bps": { "type": "number" },
        "exchange_fees_bps": { "type": "number" },
        "liquidity_tier_multiplier": { "type": "number" }
      }
    },

    "comparison_algorithms": {
      "type": "array",
      "required": false,
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "slippage_bps": { "type": "number" },
          "market_impact_bps": { "type": "number" },
          "completion_time_pct": { "type": "number" }
        }
      }
    }
  },

  "authority_assets": {
    "calculator": { "type": "string", "required": true, "format": "uri" },
    "code_hub": { "type": "string", "required": true, "format": "uri" },
    "interactive_simulator": {
      "type": "string",
      "required": false,
      "format": "uri"
    },
    "comparisons": {
      "type": "array",
      "required": false,
      "maxItems": 4,
      "items": { "type": "string", "format": "uri" }
    },
    "examples": {
      "type": "array",
      "required": false,
      "maxItems": 3,
      "items": { "type": "string", "format": "uri" }
    },
    "benchmarks": {
      "type": "array",
      "required": false,
      "maxItems": 3,
      "items": { "type": "string", "format": "uri" }
    },
    "related_execution_concepts": {
      "type": "array",
      "required": false,
      "maxItems": 5,
      "items": { "type": "string", "format": "uri" }
    },
    "related_algorithms": {
      "type": "array",
      "required": false,
      "maxItems": 4,
      "items": { "type": "string", "format": "uri" }
    }
  },

  "content_sections": {
    "required": {
      "minItems": 5,
      "maxItems": 5,
      "items": [
        {
          "id": { "type": "string", "const": "quick_answer" },
          "type": { "type": "string", "const": "highlight_box" },
          "title": {
            "type": "string",
            "required": true,
            "minLength": 10,
            "maxLength": 30
          },
          "content": {
            "type": "string",
            "required": true,
            "minLength": 80,
            "maxLength": 150
          }
        },
        {
          "id": { "type": "string", "const": "interactive_simulator" },
          "type": { "type": "string", "const": "interactive_widget" },
          "title": {
            "type": "string",
            "required": true,
            "minLength": 15,
            "maxLength": 35
          },
          "widget_type": { "type": "string", "const": "execution_simulator" }
        },
        {
          "id": { "type": "string", "const": "algorithm_logic" },
          "type": { "type": "string", "const": "code_block" },
          "title": {
            "type": "string",
            "required": true,
            "minLength": 5,
            "maxLength": 20
          },
          "content": {
            "type": "string",
            "required": true,
            "minLength": 50,
            "maxLength": 300
          }
        },
        {
          "id": { "type": "string", "const": "performance_metrics" },
          "type": { "type": "string", "const": "signal_table" },
          "title": {
            "type": "string",
            "required": true,
            "minLength": 15,
            "maxLength": 35
          },
          "rows": {
            "type": "array",
            "required": true,
            "minItems": 3,
            "maxItems": 5,
            "items": {
              "type": "object",
              "properties": {
                "metric": {
                  "type": "string",
                  "minLength": 20,
                  "maxLength": 40
                },
                "typical_value": {
                  "type": "string",
                  "minLength": 30,
                  "maxLength": 80
                }
              }
            }
          }
        },
        {
          "id": { "type": "string", "const": "code_implementations" },
          "type": { "type": "string", "const": "language_grid" },
          "title": {
            "type": "string",
            "required": true,
            "minLength": 15,
            "maxLength": 30
          },
          "languages": {
            "type": "array",
            "required": true,
            "minItems": 6,
            "maxItems": 22,
            "items": {
              "type": "string",
              "enum": [
                "python",
                "rust",
                "go",
                "cpp",
                "java",
                "javascript",
                "typescript",
                "csharp",
                "ruby",
                "swift",
                "kotlin",
                "php",
                "r",
                "julia",
                "scala",
                "haskell",
                "ocaml",
                "fsharp",
                "matlab",
                "zig",
                "dotnet",
                "sql"
              ]
            }
          }
        }
      ]
    },
    "recommended": {
      "minItems": 0,
      "maxItems": 5,
      "items": [
        {
          "id": {
            "type": "string",
            "enum": [
              "use_cases",
              "parameter_tuning",
              "pros_cons",
              "comparison",
              "cost_analysis",
              "optimization_tips"
            ]
          },
          "type": {
            "type": "string",
            "enum": ["text", "step_by_step", "cards", "two_columns", "chart"]
          },
          "title": {
            "type": "string",
            "required": true,
            "minLength": 10,
            "maxLength": 35
          },
          "content": {
            "type": "string",
            "required": false,
            "minLength": 150,
            "maxLength": 400
          },
          "items": {
            "type": "array",
            "required": false,
            "minItems": 2,
            "maxItems": 5
          },
          "chart_config": {
            "type": "object",
            "required": false,
            "properties": {
              "type": { "type": "string", "enum": ["bar", "line", "area"] },
              "x_axis": { "type": "string" },
              "y_axis": { "type": "string" }
            }
          }
        }
      ]
    },
    "optional": {
      "minItems": 0,
      "maxItems": 4,
      "items": [
        {
          "id": {
            "type": "string",
            "enum": [
              "mathematical_model",
              "implementation_details",
              "optimization_techniques",
              "risk_considerations",
              "regulatory_compliance"
            ]
          },
          "type": {
            "type": "string",
            "enum": ["text", "code_block", "warning_box"]
          },
          "title": {
            "type": "string",
            "required": true,
            "minLength": 5,
            "maxLength": 25
          },
          "content": {
            "type": "string",
            "required": true,
            "minLength": 100,
            "maxLength": 300
          },
          "code": { "type": "string", "required": false },
          "language": { "type": "string", "required": false }
        }
      ]
    }
  },

  "engagement_widgets": {
    "interactive_simulator": { "type": "boolean", "required": true },
    "calculator_preview": { "type": "boolean", "required": true },
    "code_language_selector": { "type": "boolean", "required": true },
    "comparison_links": { "type": "boolean", "required": true },
    "related_execution_concepts": { "type": "boolean", "required": true },
    "faq_accordion": { "type": "boolean", "required": true },
    "performance_simulator": { "type": "boolean", "required": true },
    "cost_analyzer": { "type": "boolean", "required": false },
    "export_results": { "type": "boolean", "required": false },
    "share_simulation": { "type": "boolean", "required": false }
  },

  "visualization_config": {
    "type": "object",
    "required": false,
    "properties": {
      "default_chart": {
        "type": "string",
        "enum": ["cost_breakdown", "slippage_curve", "execution_timeline"]
      },
      "color_scheme": {
        "type": "string",
        "enum": ["default", "performance", "risk"]
      },
      "show_cost_components": { "type": "boolean", "default": true },
      "animate_transitions": { "type": "boolean", "default": true }
    }
  },

  "faq": {
    "type": "array",
    "required": true,
    "minItems": 2,
    "maxItems": 4,
    "items": {
      "type": "object",
      "properties": {
        "q": { "type": "string", "minLength": 20, "maxLength": 90 },
        "a": { "type": "string", "minLength": 80, "maxLength": 250 }
      }
    }
  },

  "metadata": {
    "estimated_read_time": {
      "type": "string",
      "required": true,
      "pattern": "^\\d+ min read$"
    },
    "last_updated": { "type": "string", "required": true, "format": "date" },
    "difficulty": {
      "type": "string",
      "required": true,
      "enum": ["beginner", "intermediate", "advanced", "expert"]
    },
    "content_type": {
      "type": "string",
      "required": true,
      "const": "execution_guide"
    },
    "tags": {
      "type": "array",
      "required": true,
      "minItems": 2,
      "maxItems": 5,
      "items": { "type": "string", "minLength": 3, "maxLength": 15 }
    },
    "featured": { "type": "boolean", "required": false, "default": false },
    "popularity_score": {
      "type": "number",
      "required": false,
      "minimum": 0,
      "maximum": 100
    }
  }
}
