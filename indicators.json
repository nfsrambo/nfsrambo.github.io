{
  "name": "{slug}",
  "path": "/indicators/{slug}",
  "depth_level": 2,
  "breadcrumb": ["Home", "Technical Indicators", "{display_name}"],
  "parent": "/indicators",
  "category": "indicators",

  "meta": {
    "title": {
      "type": "string",
      "required": true,
      "minLength": 35,
      "maxLength": 55
    },
    "description": {
      "type": "string",
      "required": true,
      "minLength": 120,
      "maxLength": 155
    },
    "canonical": { "type": "string", "required": true, "format": "uri" }
  },

  "seo_schema": {
    "@context": {
      "type": "string",
      "required": true,
      "const": "https://schema.org"
    },
    "@type": { "type": "string", "required": true, "const": "TechArticle" },
    "headline": {
      "type": "string",
      "required": true,
      "minLength": 35,
      "maxLength": 100
    },
    "datePublished": { "type": "string", "required": true, "format": "date" },
    "dateModified": { "type": "string", "required": true, "format": "date" }
  },

  "aeo": {
    "direct_answer": {
      "type": "string",
      "required": true,
      "minLength": 100,
      "maxLength": 200
    },
    "key_takeaways": {
      "type": "array",
      "required": true,
      "minItems": 3,
      "maxItems": 4,
      "items": { "type": "string", "minLength": 40, "maxLength": 100 }
    },
    "people_also_ask": {
      "type": "array",
      "required": true,
      "minItems": 2,
      "maxItems": 3,
      "items": {
        "type": "object",
        "properties": {
          "question": { "type": "string", "minLength": 30, "maxLength": 90 },
          "answer": { "type": "string", "minLength": 60, "maxLength": 200 }
        }
      }
    }
  },

  "indicator_specific": {
    "type": {
      "type": "string",
      "required": true,
      "enum": ["oscillator", "trend", "volatility", "volume", "momentum"]
    },
    "range_min": { "type": "number", "required": false },
    "range_max": { "type": "number", "required": false },
    "overbought": { "type": "number", "required": false },
    "oversold": { "type": "number", "required": false },
    "centerline": { "type": "number", "required": false },
    "default_period": {
      "type": "number",
      "required": true,
      "minimum": 1,
      "maximum": 200
    },
    "lagging": { "type": "boolean", "required": true },
    "supports_divergence": { "type": "boolean", "required": true },
    "interactive_widget": { "type": "boolean", "required": true },
    "widget_config": {
      "type": "object",
      "required": false,
      "properties": {
        "type": {
          "type": "string",
          "required": true,
          "enum": [
            "rsi_simulator",
            "macd_simulator",
            "atr_simulator",
            "adx_simulator",
            "stochastic_simulator",
            "bollinger_simulator"
          ]
        },
        "default_period": { "type": "number", "required": false },
        "default_overbought": { "type": "number", "required": false },
        "default_oversold": { "type": "number", "required": false },
        "default_fast_period": { "type": "number", "required": false },
        "default_slow_period": { "type": "number", "required": false },
        "default_signal_period": { "type": "number", "required": false },
        "default_multiplier": { "type": "number", "required": false }
      }
    }
  },

  "authority_assets": {
    "calculator": { "type": "string", "required": true, "format": "uri" },
    "code_hub": { "type": "string", "required": true, "format": "uri" },
    "comparisons": {
      "type": "array",
      "required": false,
      "maxItems": 4,
      "items": { "type": "string", "format": "uri" }
    },
    "examples": {
      "type": "array",
      "required": false,
      "maxItems": 3,
      "items": { "type": "string", "format": "uri" }
    },
    "benchmarks": {
      "type": "array",
      "required": false,
      "maxItems": 3,
      "items": { "type": "string", "format": "uri" }
    },
    "related_indicators": ["/indicators/*", "/indicators/*", "/indicators/*"]
  },

  "content_sections": {
    "required": {
      "minItems": 5,
      "maxItems": 5,
      "items": [
        {
          "id": "quick_answer",
          "type": "highlight_box",
          "title": {
            "type": "string",
            "required": true,
            "minLength": 10,
            "maxLength": 30
          },
          "content": {
            "type": "string",
            "required": true,
            "minLength": 80,
            "maxLength": 150
          }
        },
        {
          "id": "interactive_simulator",
          "type": "interactive_widget",
          "title": {
            "type": "string",
            "required": true,
            "minLength": 15,
            "maxLength": 35
          },
          "widget_type": { "type": "string", "required": true }
        },
        {
          "id": "formula",
          "type": "code_block",
          "title": {
            "type": "string",
            "required": true,
            "minLength": 5,
            "maxLength": 20
          },
          "content": {
            "type": "string",
            "required": true,
            "minLength": 50,
            "maxLength": 300
          }
        },
        {
          "id": "signals",
          "type": "signal_table",
          "title": {
            "type": "string",
            "required": true,
            "minLength": 15,
            "maxLength": 35
          },
          "rows": {
            "type": "array",
            "required": true,
            "minItems": 3,
            "maxItems": 5,
            "items": {
              "type": "object",
              "properties": {
                "signal": {
                  "type": "string",
                  "minLength": 20,
                  "maxLength": 40
                },
                "meaning": {
                  "type": "string",
                  "minLength": 30,
                  "maxLength": 80
                }
              }
            }
          }
        },
        {
          "id": "code_implementations",
          "type": "language_grid",
          "title": {
            "type": "string",
            "required": true,
            "minLength": 15,
            "maxLength": 30
          },
          "languages": {
            "type": "array",
            "required": true,
            "minItems": 6,
            "maxItems": 22,
            "items": {
              "type": "string",
              "enum": [
                "python",
                "rust",
                "go",
                "cpp",
                "java",
                "javascript",
                "typescript",
                "csharp",
                "ruby",
                "swift",
                "kotlin",
                "php",
                "r",
                "julia",
                "scala",
                "haskell",
                "ocaml",
                "fsharp",
                "matlab",
                "zig",
                "dotnet",
                "sql"
              ]
            }
          }
        }
      ]
    },
    "recommended": {
      "minItems": 0,
      "maxItems": 4,
      "items": [
        {
          "id": {
            "type": "string",
            "enum": [
              "how_it_works",
              "calculation_example",
              "trading_strategies",
              "pros_cons"
            ]
          },
          "type": {
            "type": "string",
            "enum": ["text", "step_by_step", "cards", "two_columns"]
          },
          "title": {
            "type": "string",
            "required": true,
            "minLength": 10,
            "maxLength": 35
          },
          "content": {
            "type": "string",
            "required": false,
            "minLength": 150,
            "maxLength": 400
          },
          "items": {
            "type": "array",
            "required": false,
            "minItems": 2,
            "maxItems": 5
          }
        }
      ]
    },
    "optional": {
      "minItems": 0,
      "maxItems": 3,
      "items": [
        {
          "id": {
            "type": "string",
            "enum": ["history", "market_conditions", "common_mistakes"]
          },
          "type": { "type": "string", "const": "text" },
          "title": {
            "type": "string",
            "required": true,
            "minLength": 5,
            "maxLength": 25
          },
          "content": {
            "type": "string",
            "required": true,
            "minLength": 100,
            "maxLength": 300
          }
        }
      ]
    }
  },

  "engagement_widgets": {
    "calculator_preview": { "type": "boolean", "required": true },
    "code_language_selector": { "type": "boolean", "required": true },
    "comparison_links": { "type": "boolean", "required": true },
    "related_indicators": { "type": "boolean", "required": true },
    "faq_accordion": { "type": "boolean", "required": true },
    "indicator_simulator": { "type": "boolean", "required": true }
  },

  "faq": {
    "type": "array",
    "required": true,
    "minItems": 2,
    "maxItems": 3,
    "items": {
      "type": "object",
      "properties": {
        "q": { "type": "string", "minLength": 20, "maxLength": 90 },
        "a": { "type": "string", "minLength": 80, "maxLength": 250 }
      }
    }
  },

  "metadata": {
    "estimated_read_time": {
      "type": "string",
      "required": true,
      "pattern": "^\\d+ min read$"
    },
    "last_updated": { "type": "string", "required": true, "format": "date" },
    "difficulty": {
      "type": "string",
      "required": true,
      "enum": ["beginner", "intermediate", "advanced"]
    },
    "content_type": {
      "type": "string",
      "required": true,
      "const": "indicator_guide"
    },
    "tags": {
      "type": "array",
      "required": true,
      "minItems": 2,
      "maxItems": 5,
      "items": { "type": "string", "minLength": 3, "maxLength": 15 }
    }
  }
}
